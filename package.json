{
  "name": "trading_plataform",
  "version": "1.0.0",
  "description": "Este conteúdo é parte do curso Clean Code e Clean Architecture da Branas.io",
  "main": "index.js",
  "scripts": {
    "main": "ts-node csrc/main.ts",
    "dev": "nodemon -L --exec ts-node lssrc/main.ts",
    "test": "jest --config jest.config.js",
    "docker:build": "docker build -t trading_plataform docker",
    "docker:run": "docker run -it -v %cd%:/app trading_plataform bash",
    "compose:up": "docker-compose -f docker/docker-compose.yaml up -d",
    "compose:down": "docker-compose -f docker/docker-compose.yaml -v down",
    "compose:exec": "docker-compose -f docker/docker-compose.yaml exec -it backend bash"
  }
}
